              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Room hat erwartete Felder', () => {",
                  "    const data = pm.response.json();",
                  "    pm.expect(data).to.have.property('roomCode');",
                  "    pm.expect(data).to.have.property('room_phase');",
                  "    pm.expect(data).to.have.property('game_type');",
                  "    pm.expect(data).to.have.property('scores');",
                  "    pm.expect(data).to.have.property('activePlayers');",
                  "});",
                  "pm.test('room_phase ist LOBBY', () => {",
                  "    pm.expect(pm.response.json().room_phase).to.equal('LOBBY');",
                  "});",
                  "pm.test('game_type ist jeopardy', () => {",
                  "    pm.expect(pm.response.json().game_type).to.equal('jeopardy');",
                  "});",
