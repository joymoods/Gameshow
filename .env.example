# =============================================================================
# Root-Konfiguration – wird von Docker Compose gelesen
# Kopieren: cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# ADMIN_TOKEN
# Schützt alle Admin-API-Routen im Go-Backend (/api/rooms/*, /api/library write).
# Wird auch automatisch als VITE_ADMIN_TOKEN ins Admin-Frontend übernommen
# (via `make build` oder `scripts/sync-env.sh`).
#
# Erzeugen:
#   openssl rand -hex 32
# -----------------------------------------------------------------------------
ADMIN_TOKEN=

# -----------------------------------------------------------------------------
# ADMIN_PASSWORD_HASH
# Bcrypt-Hash für das HTTP-Basic-Auth-Passwort des Admin-Frontends (/admin/*).
# Kann ein anderes Passwort sein als der ADMIN_TOKEN, oder dasselbe.
#
# Erzeugen:
#   docker run --rm -it caddy:2-alpine caddy hash-password
#   (interaktiv – Passwort eingeben, Hash kopieren)
#
# WICHTIG – Dollar-Escaping für Docker Compose:
#   Alle '$' im bcrypt-Hash müssen als '$$' geschrieben werden, da Docker Compose
#   '$'-Zeichen sonst als Variablenreferenzen interpretiert und den Hash zerstört.
#   Beispiel: $2a$14$abc...  →  $$2a$$14$$abc...
# -----------------------------------------------------------------------------
ADMIN_PASSWORD_HASH=
