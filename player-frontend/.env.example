# =============================================================================
# Player-Frontend – Vite Build-Konfiguration (lokale Entwicklung)
# Kopieren: cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# VITE_API_URL
# URL des Go-Backends. Leer lassen wenn Player-Frontend und Backend über
# denselben Host laufen (z.B. hinter Caddy) – dann wird window.location.hostname
# genutzt.
#
# Lokal (Backend direkt):  http://localhost:8080
# Lokal (mit Caddy):       leer lassen
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8080
