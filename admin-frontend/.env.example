# =============================================================================
# Admin-Frontend – Vite Build-Konfiguration (lokale Entwicklung)
# Kopieren: cp .env.example .env
#
# Für Produktions-Builds: `make build` oder `scripts/sync-env.sh` nutzen –
# dann wird VITE_ADMIN_TOKEN automatisch aus der Root-.env übernommen und
# muss hier nicht manuell eingetragen werden.
# =============================================================================

# -----------------------------------------------------------------------------
# VITE_API_URL
# URL des Go-Backends. Leer lassen wenn Admin-Frontend und Backend über denselben
# Host laufen (z.B. hinter Caddy) – dann wird window.location.hostname genutzt.
#
# Lokal (Backend direkt):  http://localhost:8080
# Lokal (mit Caddy):       leer lassen
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# VITE_PLAYER_URL
# Öffentliche URL des Player-Frontends – wird im QR-Code der Lobby angezeigt.
#
# Lokal:       http://localhost:5174
# Produktion:  https://deine-domain.de
# -----------------------------------------------------------------------------
VITE_PLAYER_URL=http://localhost:5174

# -----------------------------------------------------------------------------
# VITE_ADMIN_TOKEN
# Bearer-Token für alle Admin-API-Aufrufe. MUSS identisch sein mit ADMIN_TOKEN
# in der Root-.env (../. env).
#
# Bei `make build` / `scripts/sync-env.sh` wird dieser Wert automatisch
# aus der Root-.env gelesen und gesetzt – hier nur für lokale Entwicklung
# manuell eintragen:
#   grep ADMIN_TOKEN ../.env
# -----------------------------------------------------------------------------
VITE_ADMIN_TOKEN=

# -----------------------------------------------------------------------------
# VITE_ADMIN_PIN  (optional)
# Zusätzlicher clientseitiger PIN-Schutz vor dem Admin-Interface.
# Leer lassen = deaktiviert.
# -----------------------------------------------------------------------------
VITE_ADMIN_PIN=
