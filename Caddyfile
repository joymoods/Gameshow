:80 {
    # Backend API
    handle /api/* {
        reverse_proxy backend:8080
    }

    # WebSocket
    handle /ws {
        reverse_proxy backend:8080
    }

    # Medien-Uploads
    handle /media/* {
        reverse_proxy backend:8080
    }

    # Admin-Frontend (unter /admin)
    handle /admin {
        redir * /admin/ 301
    }
    handle_path /admin/* {
        root * /srv/admin
        try_files {path} /index.html
        file_server
    }

    # Player-Frontend (Root)
    handle {
        root * /srv/player
        try_files {path} /index.html
        file_server
    }
}
